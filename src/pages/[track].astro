                points={100}
                position="bottom-left"
            />
            {/* Add other fun/game components here as needed */}
        </>
    )}
    <script>
      const toggles = document.querySelectorAll('[data-expand-toggle]');
      toggles.forEach((toggle) => {
        toggle.addEventListener('click', () => {
          const targetId = toggle.getAttribute('data-target');
          if (!targetId) return;
          const target = document.getElementById(targetId);
          if (!target) return;
          const isHidden = target.classList.contains('hidden');
          target.classList.toggle('hidden', !isHidden);
          const moreLabel = toggle.getAttribute('data-more-label') || 'Show more';
          const lessLabel = toggle.getAttribute('data-less-label') || 'Show less';
          const label = toggle.querySelector('[data-expand-label]');
          if (label) {
            label.textContent = isHidden ? lessLabel : moreLabel;
          } else {
            toggle.textContent = isHidden ? lessLabel : moreLabel;
          }
        });
      });
    </script>
</Layout>
